{
  "name": "@thream/api",
  "version": "1.0.0",
  "description": "Thream's application programming interface to stay close with your friends and communities.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Thream/api"
  },
  "husky": {
    "hooks": {
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS",
      "pre-commit": "npm run lint"
    }
  },
  "release-it": {
    "git": {
      "commitMessage": "chore(release): v${version}"
    },
    "github": {
      "release": false
    },
    "npm": {
      "publish": false
    },
    "hooks": {
      "before:init": [
        "npm run lint",
        "npm run test"
      ]
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": "angular",
        "infile": "CHANGELOG.md"
      }
    }
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "setupFiles": [
      "./__test__/setEnvsVars.ts"
    ],
    "setupFilesAfterEnv": [
      "./__test__/setup.ts"
    ],
    "rootDir": "./src",
    "collectCoverage": true,
    "coverageDirectory": "../coverage/"
  },
  "ts-standard": {
    "files": [
      "./src/**/*.ts"
    ],
    "envs": [
      "node",
      "jest"
    ]
  },
  "scripts": {
    "build": "rimraf ./build && tsc",
    "start": "cross-env NODE_ENV=production node build/index.js",
    "dev": "concurrently -k -n \"TypeScript,Node\" -p \"[{name}]\" -c \"blue,green\" \"tsc --watch\" \"cross-env NODE_ENV=development nodemon -e js,json,yaml build/index.js\"",
    "lint": "ts-standard | snazzy",
    "format": "ts-standard --fix | snazzy",
    "release": "release-it",
    "test": "jest",
    "test:watchAll": "jest --watchAll",
    "test:clearCache": "jest --clearCache",
    "postinstall": "copy-env-cli",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@thream/socketio-jwt": "1.1.0",
    "axios": "0.21.1",
    "bcryptjs": "2.4.3",
    "cors": "2.8.5",
    "dotenv": "8.2.0",
    "ejs": "3.1.5",
    "express": "4.17.1",
    "express-async-errors": "3.1.1",
    "express-fileupload": "1.2.1",
    "express-http-to-https": "1.1.4",
    "express-rate-limit": "5.2.3",
    "express-validator": "6.9.2",
    "helmet": "4.4.1",
    "jsonwebtoken": "8.5.1",
    "morgan": "1.10.0",
    "ms": "2.1.3",
    "mysql2": "2.2.5",
    "nodemailer": "6.4.17",
    "reflect-metadata": "0.1.13",
    "sequelize": "6.3.5",
    "sequelize-typescript": "2.0.0",
    "socket.io": "3.1.0",
    "swagger-jsdoc": "6.0.1",
    "swagger-ui-express": "4.1.6",
    "tslib": "2.1.0",
    "uuid": "8.3.2"
  },
  "devDependencies": {
    "@commitlint/cli": "11.0.0",
    "@commitlint/config-conventional": "11.0.0",
    "@release-it/conventional-changelog": "2.0.0",
    "@types/bcryptjs": "2.4.2",
    "@types/cors": "2.8.9",
    "@types/ejs": "3.0.5",
    "@types/express": "4.17.11",
    "@types/express-fileupload": "1.1.6",
    "@types/express-rate-limit": "5.1.1",
    "@types/jest": "26.0.20",
    "@types/jsonwebtoken": "8.5.0",
    "@types/mock-fs": "4.13.0",
    "@types/morgan": "1.9.2",
    "@types/ms": "0.7.31",
    "@types/node": "14.14.21",
    "@types/nodemailer": "6.4.0",
    "@types/server-destroy": "1.0.1",
    "@types/supertest": "2.0.10",
    "@types/swagger-jsdoc": "6.0.0",
    "@types/swagger-ui-express": "4.1.2",
    "@types/uuid": "8.3.0",
    "@types/validator": "13.1.3",
    "concurrently": "5.3.0",
    "copy-env-cli": "1.0.0",
    "cross-env": "7.0.3",
    "husky": "4.3.8",
    "jest": "26.6.3",
    "mock-fs": "4.13.0",
    "nodemon": "2.0.7",
    "release-it": "14.2.2",
    "rimraf": "3.0.2",
    "server-destroy": "1.0.1",
    "snazzy": "9.0.0",
    "socket.io-client": "3.1.0",
    "sqlite": "4.0.19",
    "sqlite3": "5.0.1",
    "supertest": "6.1.1",
    "ts-jest": "26.4.4",
    "ts-standard": "10.0.0",
    "typescript": "4.1.3"
  }
}
